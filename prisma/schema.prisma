generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Product {
  id            String   @id @default(cuid())
  name          String
  description   String?
  price         Float
  originalPrice Float?
  img           String
  hoverImg      String?
  categories    String
  badge         String?
  stock         Int      @default(100)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Order {
  id              String    @id @default(cuid())
  customerName    String
  customerEmail   String?
  customerPhone   String
  zila            String
  upozila         String
  shippingAddress String
  status          String    @default("Pending")
  totalAmount     Float
  items           String
  customerId      String?
  idempotencyKey  String?   @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  customer        Customer? @relation(fields: [customerId], references: [id])
}

model Customer {
  id         String   @id @default(cuid())
  name       String
  email      String?  @unique
  phone      String   @unique
  zila       String?
  upozila    String?
  location   String?
  tier       String   @default("Bronze")
  totalSpend Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  orders     Order[]
}

model AdminSettings {
  id               String   @id @default(cuid())
  firstName        String   @default("Admin")
  lastName         String   @default("User")
  email            String   @unique
  bio              String?
  emailAlerts      Boolean  @default(true)
  orderNotifs      Boolean  @default(true)
  marketingUpdates Boolean  @default(false)
  avatarUrl        String?
  updatedAt        DateTime @updatedAt
}

model CMSContent {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  section   String   @default("general")
  updatedAt DateTime @updatedAt
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
